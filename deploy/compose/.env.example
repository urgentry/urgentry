# Urgentry Environment
COMPOSE_PROJECT_NAME=urgentry-selfhosted
URGENTRY_BUILD_TAGS=netgo,osusergo
URGENTRY_IMAGE=urgentry:dev
URGENTRY_ENV=production
URGENTRY_REGION=local
URGENTRY_BIND_ADDR=127.0.0.1
URGENTRY_API_PORT=8080
URGENTRY_INGEST_PORT=8081
URGENTRY_WORKER_PORT=8082
URGENTRY_SCHEDULER_PORT=8083
URGENTRY_BLOB_BACKEND=s3
URGENTRY_ASYNC_BACKEND=jetstream
URGENTRY_CACHE_BACKEND=valkey
URGENTRY_S3_BUCKET=urgentry-artifacts
URGENTRY_S3_REGION=us-east-1
URGENTRY_S3_PREFIX=
URGENTRY_BOOTSTRAP_EMAIL=admin@urgentry.local
URGENTRY_BOOTSTRAP_PASSWORD=change-me-in-production
URGENTRY_BOOTSTRAP_PAT=gpat_self_hosted_bootstrap
# serious self-hosted preflight treats blank or placeholder secrets as unsafe
URGENTRY_METRICS_TOKEN=change-me-in-production
URGENTRY_PROFILING_ENABLED=false
URGENTRY_PROFILING_TOKEN=
URGENTRY_INGEST_RATE_LIMIT=60

# PostgreSQL
POSTGRES_IMAGE=postgres:17
POSTGRES_DB=urgentry
POSTGRES_USER=urgentry
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_BIND_ADDR=127.0.0.1
POSTGRES_PORT=5432
URGENTRY_CONTROL_DATABASE_URL=postgres://urgentry:change-me-in-production@postgres:5432/urgentry?sslmode=disable
URGENTRY_TELEMETRY_DATABASE_URL=postgres://urgentry:change-me-in-production@postgres:5432/urgentry?sslmode=disable
URGENTRY_TELEMETRY_BACKEND=postgres
URGENTRY_COLUMNAR_DATABASE_URL=
URGENTRY_COLUMNAR_BACKEND=
URGENTRY_NATS_URL=nats://nats:4222
URGENTRY_VALKEY_URL=redis://valkey:6379/0

# Optional logs-only ClickHouse pilot
CLICKHOUSE_IMAGE=clickhouse/clickhouse-server:25.3
CLICKHOUSE_DB=urgentry
CLICKHOUSE_USER=urgentry
CLICKHOUSE_PASSWORD=change-me-in-production
# To enable the pilot, add:
# COMPOSE_PROFILES=columnar
# URGENTRY_BUILD_TAGS=netgo,osusergo,clickhouse
# URGENTRY_COLUMNAR_DATABASE_URL=clickhouse://urgentry:change-me-in-production@clickhouse:9000/urgentry
# URGENTRY_COLUMNAR_BACKEND=clickhouse

# MinIO (S3-compatible object storage)
MINIO_IMAGE=minio/minio:RELEASE.2025-09-07T16-13-09Z
MINIO_MC_IMAGE=minio/mc:RELEASE.2025-08-13T08-35-41Z
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change-me-in-production
MINIO_BIND_ADDR=127.0.0.1
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Valkey (Redis-compatible cache)
VALKEY_IMAGE=valkey/valkey:8
VALKEY_BIND_ADDR=127.0.0.1
VALKEY_PORT=6379

# NATS (async messaging)
NATS_IMAGE=nats:2.11-alpine
NATS_BIND_ADDR=127.0.0.1
NATS_PORT=4222
NATS_MONITOR_PORT=8222
