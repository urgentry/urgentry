URGENTRY_ENV=development
URGENTRY_HTTP_ADDR=:8080
URGENTRY_DATA_DIR=
URGENTRY_BLOB_BACKEND=file
URGENTRY_S3_ENDPOINT=
URGENTRY_S3_BUCKET=
URGENTRY_S3_ACCESS_KEY=
URGENTRY_S3_SECRET_KEY=
URGENTRY_S3_REGION=us-east-1
URGENTRY_S3_PREFIX=
URGENTRY_S3_USE_TLS=false
URGENTRY_INGEST_RATE_LIMIT=60
URGENTRY_PIPELINE_QUEUE_SIZE=1000
# Leave blank for the runtime default: Tiny=1, serious self-hosted=4
URGENTRY_PIPELINE_WORKERS=
URGENTRY_HTTP_READ_HEADER_TIMEOUT=5s
URGENTRY_HTTP_READ_TIMEOUT=30s
URGENTRY_HTTP_WRITE_TIMEOUT=30s
URGENTRY_HTTP_IDLE_TIMEOUT=60s
URGENTRY_METRICS_TOKEN=
